---
// Heavy inspiration taken from Astro Starlight -> https://github.com/withastro/starlight/blob/main/packages/starlight/components/Search.astro

import "@pagefind/component-ui/css";

const baseUrl = import.meta.env.BASE_URL;
const pagefindBundlePath = `${baseUrl.replace(/\/$/, "")}/pagefind/`;
const resultTemplate = String.raw`
<li class="webtrotion-search-result">
	<div class="webtrotion-search-result-card">
		<span class="webtrotion-search-result-icon" aria-hidden="true">
			<svg viewBox="0 0 24 24" focusable="false">
				<path d="M6 3.75h8.4L19 8.35v11.9H6z" />
				<path d="M14.25 4v4.6h4.5" />
				<path d="M8.75 12h6.5M8.75 15h5M8.75 18h3.75" />
			</svg>
		</span>
		<div class="webtrotion-search-result-main">
			<a class="webtrotion-search-result-link" href="{{ meta.url | default(url) | safeUrl }}">
				{{ meta.title | default("Untitled") }}
			</a>
			<p class="webtrotion-search-result-url">{{ meta.url | default(url) }}</p>
			{{#if excerpt}}
				<p class="webtrotion-search-result-excerpt">{{+ excerpt +}}</p>
			{{/if}}
		</div>
	</div>
	{{#if sub_results}}
		<ul class="webtrotion-search-subresults" aria-label="Matching sections">
			{{#each sub_results as sub}}
				<li>
					<a class="webtrotion-search-subresult-link" href="{{ sub.url | safeUrl }}">
						{{ sub.title | default("Section") }}
					</a>
					{{#if sub.excerpt}}
						<p class="webtrotion-search-subresult-excerpt">{{+ sub.excerpt +}}</p>
					{{/if}}
				</li>
			{{/each}}
		</ul>
	{{/if}}
</li>`;
const placeholderTemplate = String.raw`
<li class="webtrotion-search-result webtrotion-search-placeholder" aria-hidden="true">
	<div class="webtrotion-search-result-card">
		<span class="webtrotion-search-result-icon"></span>
		<div class="webtrotion-search-result-main">
			<p class="webtrotion-search-skeleton webtrotion-search-skeleton-title"></p>
			<p class="webtrotion-search-skeleton webtrotion-search-skeleton-line"></p>
			<p class="webtrotion-search-skeleton webtrotion-search-skeleton-line short"></p>
		</div>
	</div>
</li>`;
---

<site-search id="search" class="ms-auto">
	{
		import.meta.env.DEV ? (
			<button type="button" disabled class="search-btn" aria-label="Search unavailable in dev">
				<span aria-hidden="true">⌕</span>
			</button>
		) : (
			<>
				<pagefind-config
					instance="webtrotion-search"
					bundle-path={pagefindBundlePath}
					base-url={baseUrl}
					highlight-param="highlight"
				/>
				<pagefind-modal-trigger
					instance="webtrotion-search"
					compact
					hide-shortcut
					placeholder="Search"
				/>
				<pagefind-modal id="webtrotion-search-modal" instance="webtrotion-search">
					<pagefind-modal-header>
						<pagefind-input
							instance="webtrotion-search"
							placeholder="Search this site"
							debounce="150"
						/>
					</pagefind-modal-header>
					<pagefind-modal-body>
						<div class="webtrotion-search-shell">
							<div class="webtrotion-search-filters" aria-label="Search filters">
								<pagefind-filter-dropdown
									instance="webtrotion-search"
									filter="collections"
									label="Collections"
									sort="count-desc"
									hide-clear
								/>
								<pagefind-filter-dropdown
									instance="webtrotion-search"
									filter="tags"
									label="Tags"
									sort="count-desc"
									hide-clear
								/>
							</div>
							<div class="webtrotion-search-content">
								<section class="webtrotion-search-results-pane" aria-label="Search results">
									<pagefind-summary instance="webtrotion-search" />
									<pagefind-results
										instance="webtrotion-search"
										show-images="false"
										max-sub-results="3"
									>
										<script type="text/pagefind-template" set:html={resultTemplate} />
										<script
											type="text/pagefind-template"
											data-template="placeholder"
											set:html={placeholderTemplate}
										/>
									</pagefind-results>
								</section>
								<webtrotion-search-preview instance="webtrotion-search" />
							</div>
						</div>
					</pagefind-modal-body>
					<pagefind-modal-footer>
						<pagefind-keyboard-hints instance="webtrotion-search" />
					</pagefind-modal-footer>
				</pagefind-modal>
			</>
		)
	}
</site-search>

<script>
	import "@pagefind/component-ui";
	import { getInstanceManager } from "@pagefind/component-ui";
	import type {
		PagefindRawResult,
		PagefindResultData,
		PagefindSearchResult,
		PagefindSubResult,
	} from "@pagefind/component-ui";

	const SEARCH_INSTANCE = "webtrotion-search";

	class SiteSearch extends HTMLElement {
		private resultsElement: HTMLElement | null = null;
		private onResultsKeydown = (event: KeyboardEvent) => {
			if (
				event.defaultPrevented ||
				event.altKey ||
				event.ctrlKey ||
				event.metaKey ||
				event.shiftKey
			) {
				return;
			}

			const link = (event.target as Element | null)?.closest<HTMLAnchorElement>(
				".webtrotion-search-result-link, .webtrotion-search-subresult-link",
			);
			if (!link || !this.resultsElement?.contains(link)) return;

			const result = link.closest<HTMLElement>(".webtrotion-search-result");
			if (!result) return;

			const mainLinks = Array.from(
				this.resultsElement.querySelectorAll<HTMLAnchorElement>(".webtrotion-search-result-link"),
			);
			const mainLink = result.querySelector<HTMLAnchorElement>(".webtrotion-search-result-link");
			if (!mainLink) return;

			const resultIndex = mainLinks.indexOf(mainLink);
			const subLinks = Array.from(
				result.querySelectorAll<HTMLAnchorElement>(".webtrotion-search-subresult-link"),
			);
			const subIndex = subLinks.indexOf(link);
			const isSubResult = subIndex !== -1;
			let destination: HTMLAnchorElement | undefined;

			if (!isSubResult) {
				if (event.key === "ArrowDown") destination = mainLinks[resultIndex + 1];
				if (event.key === "ArrowUp") destination = mainLinks[resultIndex - 1];
				if (event.key === "ArrowRight") destination = subLinks[0];
			} else {
				if (event.key === "ArrowDown") {
					destination = subLinks[subIndex + 1] || mainLinks[resultIndex + 1];
				}
				if (event.key === "ArrowUp") {
					destination = subLinks[subIndex - 1] || mainLink;
				}
				if (event.key === "ArrowLeft") destination = mainLink;
			}

			if (!destination) return;

			event.preventDefault();
			event.stopImmediatePropagation();
			destination.focus({ preventScroll: true });
			const scrollTarget =
				destination.closest<HTMLElement>(".webtrotion-search-subresults li") ||
				destination.closest<HTMLElement>(".webtrotion-search-result") ||
				destination;
			scrollTarget.scrollIntoView({
				behavior: event.repeat ? "auto" : "smooth",
				block: "nearest",
			});
		};

		connectedCallback() {
			if (import.meta.env.DEV) return;

			this.resultsElement = this.querySelector("pagefind-results");
			this.resultsElement?.addEventListener("keydown", this.onResultsKeydown, true);

			const queryParams = new URLSearchParams(window.location.search);
			const searchTerm = queryParams.get("q");
			if (!searchTerm) return;

			customElements.whenDefined("pagefind-modal").then(() => {
				const modal = this.querySelector("pagefind-modal") as any;
				const instance = getInstanceManager().getInstance(SEARCH_INSTANCE);
				modal?.open?.();
				instance.triggerSearch(searchTerm);
			});
		}

		disconnectedCallback() {
			this.resultsElement?.removeEventListener("keydown", this.onResultsKeydown, true);
		}
	}

	class WebtrotionSearchPreview extends HTMLElement {
		private instanceName = SEARCH_INSTANCE;
		private resultDataByUrl = new Map<string, PagefindResultData>();
		private latestResults: PagefindRawResult[] = [];
		private eventRoot: Element | null = null;
		private onFocusOrPointer = (event: Event) => {
			const target = event.target as Element | null;
			const link = target?.closest<HTMLAnchorElement>(
				".webtrotion-search-result-link, .webtrotion-search-subresult-link",
			);
			if (!link) return;
			this.renderForUrl(link.getAttribute("href") || "");
		};

		connectedCallback() {
			if (this.hasAttribute("instance")) {
				this.instanceName = this.getAttribute("instance") || SEARCH_INSTANCE;
			}

			this.renderEmpty();
			queueMicrotask(() => {
				this.eventRoot = this.closest("pagefind-modal-body") || this.parentElement;
				this.eventRoot?.addEventListener("focusin", this.onFocusOrPointer);
				this.eventRoot?.addEventListener("pointerover", this.onFocusOrPointer);
			});

			const instance = getInstanceManager().getInstance(this.instanceName);
			instance.on(
				"loading",
				() => {
					this.latestResults = [];
					this.resultDataByUrl.clear();
					this.renderLoading();
				},
				this,
			);
			instance.on(
				"results",
				(results) => {
					const searchResults = results as PagefindSearchResult;
					this.latestResults = searchResults.results || [];
					this.resultDataByUrl.clear();
					this.renderFirstResult();
				},
				this,
			);
		}

		disconnectedCallback() {
			this.eventRoot?.removeEventListener("focusin", this.onFocusOrPointer);
			this.eventRoot?.removeEventListener("pointerover", this.onFocusOrPointer);
		}

		private normalizeUrl(url: string) {
			try {
				const parsed = new URL(url, window.location.origin);
				parsed.searchParams.delete("highlight");
				return parsed.pathname + parsed.search + parsed.hash;
			} catch {
				return url;
			}
		}

		private async renderFirstResult() {
			if (!this.latestResults.length) {
				this.renderEmpty("No preview available");
				return;
			}
			const firstResult = this.latestResults[0];
			if (!firstResult) return;
			const data = await firstResult.data();
			this.cacheResult(data);
			this.renderResult(data);
		}

		private async renderForUrl(url: string) {
			const normalized = this.normalizeUrl(url);
			const cached = this.resultDataByUrl.get(normalized);
			if (cached) {
				this.renderResult(cached);
				return;
			}

			for (const rawResult of this.latestResults) {
				const data = await rawResult.data();
				this.cacheResult(data);
				if (this.normalizeUrl(data.meta?.url || data.url) === normalized) {
					this.renderResult(data);
					return;
				}
				const subresult = data.sub_results?.find(
					(sub: PagefindSubResult) => this.normalizeUrl(sub.url) === normalized,
				);
				if (subresult) {
					this.renderSubResult(data, subresult);
					return;
				}
			}
		}

		private cacheResult(data: PagefindResultData) {
			this.resultDataByUrl.set(this.normalizeUrl(data.meta?.url || data.url), data);
			for (const subresult of data.sub_results || []) {
				this.resultDataByUrl.set(this.normalizeUrl(subresult.url), data);
			}
		}

		private renderEmpty(message = "Start typing to preview a result") {
			this.innerHTML = `<aside class="webtrotion-search-preview-card" aria-label="Search preview">
				<p class="webtrotion-search-preview-kicker">Preview</p>
				<p class="webtrotion-search-preview-empty">${message}</p>
			</aside>`;
		}

		private renderLoading() {
			this.innerHTML = `<aside class="webtrotion-search-preview-card" aria-label="Search preview" aria-busy="true">
				<p class="webtrotion-search-preview-kicker">Preview</p>
				<div class="webtrotion-search-preview-skeleton title"></div>
				<div class="webtrotion-search-preview-skeleton line"></div>
				<div class="webtrotion-search-preview-skeleton line short"></div>
			</aside>`;
		}

		private renderResult(data: PagefindResultData) {
			const title = this.escapeHtml(data.meta?.title || "Untitled");
			const url = this.escapeHtml(data.meta?.url || data.url || "");
			const excerpt = data.excerpt || "";
			const subResults = (data.sub_results || []).slice(0, 4);

			this.innerHTML = `<aside class="webtrotion-search-preview-card" aria-label="Search preview">
				<p class="webtrotion-search-preview-kicker">Best match</p>
				<h2 class="webtrotion-search-preview-title">${title}</h2>
				${url ? `<p class="webtrotion-search-preview-url">${url}</p>` : ""}
				${excerpt ? `<p class="webtrotion-search-preview-excerpt">${excerpt}</p>` : ""}
				${
					subResults.length
						? `<ul class="webtrotion-search-preview-sections">${subResults
								.map(
									(sub: PagefindSubResult) =>
										`<li><span>${this.escapeHtml(sub.title || "Section")}</span>${
											sub.excerpt ? `<p>${sub.excerpt}</p>` : ""
										}</li>`,
								)
								.join("")}</ul>`
						: ""
				}
			</aside>`;
		}

		private renderSubResult(data: PagefindResultData, subresult: PagefindSubResult) {
			this.renderResult({
				...data,
				excerpt: subresult.excerpt || data.excerpt,
				meta: {
					...data.meta,
					title: subresult.title || data.meta?.title || "Untitled",
					url: subresult.url || data.meta?.url || data.url,
				},
			});
		}

		private escapeHtml(value: string) {
			return value.replace(/[&<>"']/g, (char) => {
				switch (char) {
					case "&":
						return "&amp;";
					case "<":
						return "&lt;";
					case ">":
						return "&gt;";
					case '"':
						return "&quot;";
					case "'":
						return "&#39;";
					default:
						return char;
				}
			});
		}
	}

	if (!customElements.get("site-search")) {
		customElements.define("site-search", SiteSearch);
	}

	if (!customElements.get("webtrotion-search-preview")) {
		customElements.define("webtrotion-search-preview", WebtrotionSearchPreview);
	}
</script>
