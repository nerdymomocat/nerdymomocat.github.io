---
import Icon from "@/components/ui/Icon.astro";
const { order = 0 } = Astro.props;
// https://docs.astro.build/en/tutorial/6-islands/2/
---

<theme-toggle class:list={["ml-auto", `order-${order}`, "sm:order-3"]}>
	<button type="button" id="themeToggle" class="theme-toggle-btn group" aria-label="Toggle Theme">
		<Icon
			class="theme-icon group-data-[theme=system]:scale-100 group-data-[theme=system]:opacity-100"
			name={"theme-system"}
			aria-label="Use System Theme"
			id="system-svg"
			stroke="currentColor"
			fill="none"
			stroke-width="1.5"
			stroke-linecap="round"
		/>
		<Icon
			class="theme-icon group-data-[theme=light]:scale-100 group-data-[theme=light]:opacity-100"
			name={"theme-light"}
			aria-label="Set Light Theme"
			id="sun-svg"
			stroke="currentColor"
			fill="none"
			stroke-width="1.5"
			stroke-linecap="round"
		/>
		<Icon
			class="theme-icon group-data-[theme=dark]:scale-100 group-data-[theme=dark]:opacity-100"
			name={"theme-dark"}
			aria-label="Set Dark Theme"
			id="moon-svg"
			stroke="currentColor"
			fill="none"
			stroke-width="1.5"
			stroke-linecap="round"
		/>
	</button>
</theme-toggle>

<script is:inline>
	// The initial theme (and the <html> `dark` class) is applied by the FOUC-prevention
	// script in <head>, which also exposes `window.applyTheme`. Reuse it here so the
	// toggle button's state and the document stay in sync from a single source of truth.
	const applyTheme =
		window.applyTheme ||
		(() => {
			const theme =
				(typeof localStorage !== "undefined" && localStorage.getItem("theme")) || "system";
			const isDark =
				theme === "dark" ||
				(theme === "system" && window.matchMedia("(prefers-color-scheme: dark)").matches);
			const root = document.documentElement;
			root.classList.add("theme-switching");
			root.classList.toggle("dark", isDark);
			const btn = document.getElementById("themeToggle");
			if (btn) btn.setAttribute("data-theme", theme);
			window.requestAnimationFrame(() => {
				window.requestAnimationFrame(() => root.classList.remove("theme-switching"));
			});
		});

	// The <head> script ran before this button existed, so sync its state now.
	applyTheme();

	const handleToggleClick = (event) => {
		const current =
			(typeof localStorage !== "undefined" && localStorage.getItem("theme")) || "system";
		const newTheme = current === "system" ? "light" : current === "light" ? "dark" : "system";
		const doSwitch = () => {
			localStorage.setItem("theme", newTheme);
			applyTheme();
		};

		const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

		// No View Transitions support (e.g. Firefox) or reduced motion: switch instantly.
		if (!document.startViewTransition || prefersReducedMotion) {
			doSwitch();
			return;
		}

		// view-transition-types lets us scope the circular-reveal CSS to the toggle only,
		// so it never interferes with the cross-document page-navigation crossfade.
		const supportsTypes =
			typeof CSS !== "undefined" &&
			CSS.supports &&
			CSS.supports("selector(:active-view-transition-type(theme))");

		if (!supportsTypes) {
			// Older View-Transition browsers: a plain default crossfade is still a nice touch.
			document.startViewTransition(doSwitch);
			return;
		}

		const root = document.documentElement;

		// Reveal origin = the click point, expressed in % so the CSS radial-gradient mask
		// (which auto-sizes to the farthest corner) always fully covers the viewport.
		const rect = event?.currentTarget?.getBoundingClientRect();
		const px = event?.clientX || (rect ? rect.left + rect.width / 2 : window.innerWidth);
		const py = event?.clientY || (rect ? rect.top + rect.height / 2 : 0);
		root.style.setProperty("--vt-x", (px / window.innerWidth) * 100 + "%");
		root.style.setProperty("--vt-y", (py / window.innerHeight) * 100 + "%");

		// Duration/easing are read from CSS so the theme stays the single source of truth.
		const cs = getComputedStyle(root);
		const durRaw = cs.getPropertyValue("--theme-toggle-duration").trim();
		const duration = durRaw.endsWith("ms")
			? parseFloat(durRaw)
			: durRaw.endsWith("s")
				? parseFloat(durRaw) * 1000
				: 450;
		const easing = cs.getPropertyValue("--theme-toggle-easing").trim() || "ease";

		const transition = document.startViewTransition({ update: doSwitch, types: ["theme"] });
		transition.ready
			.then(() => {
				// Animate the registered --theme-toggle-reveal (a <percentage>) on the new
				// snapshot; the feathered mask in CSS turns it into a soft-edged growing circle.
				root.animate(
					{ "--theme-toggle-reveal": ["0%", "120%"] },
					{
						duration,
						easing,
						pseudoElement: "::view-transition-new(root)",
					},
				);
			})
			.catch(() => {
				// Transition was skipped/interrupted (e.g. rapid double toggle) — harmless.
			});
	};

	document.getElementById("themeToggle").addEventListener("click", handleToggleClick);

	// Listen for system theme changes
	window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
		const current =
			(typeof localStorage !== "undefined" && localStorage.getItem("theme")) || "system";
		if (current === "system") applyTheme();
	});
</script>
