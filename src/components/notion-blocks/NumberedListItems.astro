---
import * as interfaces from "@/lib/interfaces.ts";
import { getNotionColorToTailwindColor } from "@/utils/style-helpers";
import RichText from "@/components/notion-blocks/RichText.astro";
import NotionBlocks from "@/components/NotionBlocks.astro";

export interface Props {
	block: interfaces.Block;
	level: number;
	renderChildren?: boolean; // Make this optional
	setId?: boolean;
}

const { block, level, renderChildren = true, setId = true } = Astro.props;

const listTypes = ["lower-roman", "decimal", "lower-alpha"];
const numberedListItems = block.ListItems!.filter(
	(
		item,
	): item is interfaces.Block & {
		NumberedListItem: NonNullable<interfaces.Block["NumberedListItem"]>;
	} => item.Type === "numbered_list_item" && !!item.NumberedListItem,
);
---

<div class="numbered-list" id={setId ? block.Id : undefined}>
	<ol class="notion-list-ol" style={`list-style-type: ${listTypes[level % 3]} !important;`}>
		{
			numberedListItems.map((b) => (
				<li
					class:list={[
						{
							"notion-list-item-colored":
								b.NumberedListItem.Color &&
								!["default", "default_background", "default-background"].includes(
									b.NumberedListItem.Color,
								),
							[`${getNotionColorToTailwindColor(b.NumberedListItem.Color)}`]:
								b.NumberedListItem.Color &&
								!["default", "default_background", "default-background"].includes(
									b.NumberedListItem.Color,
								),
						},
					]}
					id={setId ? b.Id : undefined}
				>
					{b.NumberedListItem.RichTexts.map((richText: interfaces.RichText) => (
						<RichText richText={richText} blockID={b.Id} block={b} />
					))}
					{b.HasChildren && renderChildren && b.NumberedListItem.Children && (
						<NotionBlocks
							blocks={b.NumberedListItem.Children}
							level={level + 1}
							renderChildren={renderChildren}
							setId={setId}
						/>
					)}
				</li>
			))
		}
	</ol>
</div>
