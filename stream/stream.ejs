```{=html}
<%/* so category filtering works */%>
<div class="list quarto-listing-custom">

<%/* create custom listing */%>
<% for (const item of items) { %>

  <div class="quarto-post" <%= metadataAttrs(item) %>>
  
    <div class="thumbnail">

        <p style="margin-top: 5px;"><%= item['date'] %></p>
        
      </div>
    
      <div class="body">
    
        <!-- <p class="no-anchor listing-title">
    
      <%= item.title %></p> -->
    
      <div class="listing-subtitle">
        <%= item['subtitle'] %>
      </div>
      <!-- <%= item['categories'] %> -->
      <div class="listing-categories">
        <% for (const category of item.categories) { %>
        <div class="listing-category" onclick="window.quartoListingCategory('<%=category%>'); return false;"><%= category %></div>
        <% } %>
        </div>
    </div>
    
  

</div>

<% } %>

</div>
```